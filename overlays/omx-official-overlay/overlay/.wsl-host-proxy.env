#
# Canonical WSL proxy endpoint.
# With mirrored networking enabled, the Windows-side local proxy is reachable
# from WSL on 127.0.0.1. Keep both lowercase and uppercase variants because
# different tools consult different names.
#
_WSL_PROXY_HTTP="http://127.0.0.1:6984"
_WSL_PROXY_ALL="socks5h://127.0.0.1:6984"
_WSL_NO_PROXY="127.0.0.1,localhost,::1"

export http_proxy="$_WSL_PROXY_HTTP"
export https_proxy="$_WSL_PROXY_HTTP"
export HTTP_PROXY="$http_proxy"
export HTTPS_PROXY="$https_proxy"
export all_proxy="$_WSL_PROXY_ALL"
export ALL_PROXY="$all_proxy"
export no_proxy="$_WSL_NO_PROXY"
export NO_PROXY="$no_proxy"

unset _WSL_PROXY_HTTP _WSL_PROXY_ALL _WSL_NO_PROXY
