#
# User-space browser runtime libraries for Chromium-based MCP servers.
# These are extracted under ~/.local so browser-backed MCP tools can run
# without requiring sudo/apt installs inside WSL.
#
_WSL_BROWSER_LIB_DIR="$HOME/.local/opt/browser-libs/usr/lib/x86_64-linux-gnu"

if [ -d "$_WSL_BROWSER_LIB_DIR" ]; then
    case ":${LD_LIBRARY_PATH:-}:" in
        *":$_WSL_BROWSER_LIB_DIR:"*) ;;
        *)
            if [ -n "${LD_LIBRARY_PATH:-}" ]; then
                export LD_LIBRARY_PATH="$_WSL_BROWSER_LIB_DIR:$LD_LIBRARY_PATH"
            else
                export LD_LIBRARY_PATH="$_WSL_BROWSER_LIB_DIR"
            fi
            ;;
    esac
fi

unset _WSL_BROWSER_LIB_DIR
